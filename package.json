{
  "name": "worldbuilderx",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "npm@11.13.0",
  "scripts": {
    "lint": "eslint src core_data",
    "check": "npm run check:toolchain && npm run check:prerequisites && npm run lint && npm run test && npm run build && npm run desktop:build",
    "check:prerequisites": "node scripts/check-prerequisites.mjs",
    "check:toolchain": "node scripts/check-toolchain.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "build:desktop": "tauri build",
    "test": "node --test tests/*.test.mjs && npm run test:dom",
    "test:dom": "vitest run",
    "test:static": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@react-pdf/renderer": "4.5.1",
    "@tauri-apps/api": "2.11.1",
    "@tiptap/pm": "3.27.1",
    "@tiptap/react": "3.27.1",
    "@tiptap/starter-kit": "3.27.1",
    "@types/cytoscape": "3.21.9",
    "@types/leaflet": "1.9.21",
    "cytoscape": "3.34.0",
    "leaflet": "1.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-leaflet": "5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
